# Root-level ignores (common across subprojects)

# Environment files
.env
.env.local
.env.*.local

# OS
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# Node
node_modules/
frontend/dist/

# Python
**/__pycache__/
**/*.py[cod]
.venv/

# Logs
logs/
*.log
*.log.*
*.out

# Gradle and build artifacts (ignore caches/build outputs)
/.gradle/
build/
gradle-root/
gradle-home/

# But keep wrapper artifacts required to run the wrapper
!gradle/wrapper/gradle-wrapper.jar
!gradle/wrapper/gradle-wrapper.properties
!gradlew
!gradlew.bat

# IDEs
.idea/
.vscode/
*.iml
*.ipr
*.iws

# Java/IDE temp folders
out/
bin/

# Monitoring & metrics (optional local data)
prometheus-data/
grafana-data/
alertmanager-data/
monitoring-temp/

# Docker volumes / local docker overrides
docker-volumes/
docker-compose.override.yml
docker-compose.*.local.yml

# Misc
*~
