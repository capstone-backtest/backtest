# Development Dockerfile for Spring Boot
FROM eclipse-temurin:21-jdk-alpine

WORKDIR /app

# Set Gradle user home to a user-specific directory (prevents using /app)
ENV GRADLE_USER_HOME=/home/spring/.gradle

# Install wget and bash for the Gradle wrapper shebang
# gradlew generated script uses #!/bin/bash; Alpine doesn't include bash by default
RUN apk add --no-cache wget bash

# Copy gradle wrapper and build files
COPY gradlew .
COPY gradle ./gradle
COPY build.gradle .
COPY settings.gradle .
COPY gradle.properties .

# Make gradlew executable
RUN chmod +x gradlew

# If the Gradle wrapper jar is missing in the repository, fall back to
# downloading an official Gradle distribution at build time and use its
# `gradle` binary. This avoids failing the image build when the wrapper jar
# wasn't committed. Downloading avoids relying on a local `gradle-8.10-bin.zip`.
ARG GRADLE_VERSION=8.10
RUN set -eux; \
  GRADLE_ZIP="gradle-${GRADLE_VERSION}-bin.zip"; \
  URL="https://services.gradle.org/distributions/${GRADLE_ZIP}"; \
  wget -q "$URL" -O "/tmp/${GRADLE_ZIP}"; \
  unzip "/tmp/${GRADLE_ZIP}" -d /opt; \
  ln -s "/opt/gradle-${GRADLE_VERSION}/bin/gradle" /usr/local/bin/gradle || true; \
  rm -f "/tmp/${GRADLE_ZIP}"

# Copy source code
COPY src ./src

# Create non-root user
RUN addgroup -g 1000 spring && \
  adduser -u 1000 -G spring -s /bin/sh -D spring && \
  mkdir -p ${GRADLE_USER_HOME} && \
  chown -R spring:spring /app ${GRADLE_USER_HOME}

USER spring

# Health check
HEALTHCHECK --interval=30s --timeout=3s --start-period=60s --retries=3 \
  CMD wget --no-verbose --tries=1 --spider http://localhost:8080/actuator/health || exit 1

EXPOSE 8080

# Development command with auto-reload
CMD ["./gradlew", "bootRun", "--no-daemon"]